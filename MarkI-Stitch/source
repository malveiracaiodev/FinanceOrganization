import 'package:flutter/material.dart';

// --- Adicionar Transação Screen ---
class AddTransactionScreen extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: Color(0xFF010F1F),
      body: Stack(
        children: [
          Container(
            decoration: BoxDecoration(
              gradient: LinearGradient(
                begin: Alignment.topCenter,
                end: Alignment.bottomCenter,
                colors: [Color(0xFF051424), Color(0xFF010F1F)],
              ),
            ),
          ),
          SafeArea(
            child: Padding(
              padding: EdgeInsets.all(24),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  _buildHeader(),
                  SizedBox(height: 40),
                  Text('Nova Operação', style: TextStyle(fontSize: 32, fontWeight: FontWeight.bold, color: Colors.white)),
                  SizedBox(height: 8),
                  Text('Configure os parâmetros da sua missão financeira.', style: TextStyle(color: Colors.white60, fontSize: 14)),
                  SizedBox(height: 40),
                  _buildFieldLabel('IDENTIFICADOR DA TRANSAÇÃO'),
                  _buildTextField('Ex: Assinatura Orbital', Icons.subject),
                  SizedBox(height: 32),
                  _buildFieldLabel('MAGNITUDE (VALOR)'),
                  _buildTextField('0,00', null, prefix: 'R\$'),
                  SizedBox(height: 32),
                  _buildFieldLabel('VETOR (TIPO)'),
                  SizedBox(height: 12),
                  Text('Gasto (Saída)', style: TextStyle(color: Colors.white, fontSize: 18)),
                  SizedBox(height: 32),
                  Row(
                    mainAxisAlignment: MainAxisAlignment.spaceBetween,
                    children: [
                      _buildFieldLabel('NÍVEL DE IMPACTO'),
                      Text('ESTÁVEL', style: TextStyle(color: Colors.white, fontSize: 14, letterSpacing: 1)),
                    ],
                  ),
                  SizedBox(height: 16),
                  _buildImpactSlider(),
                  Spacer(),
                  _buildSubmitButton(),
                ],
              ),
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildHeader() {
    return Row(
      mainAxisAlignment: MainAxisAlignment.spaceBetween,
      children: [
        Row(
          children: [
            Icon(Icons.rocket_launch, color: Color(0xFF00EEFC)),
            SizedBox(width: 10),
            Text('FINANÇAS MARK I', style: TextStyle(fontSize: 18, fontWeight: FontWeight.bold, letterSpacing: -1, color: Colors.white)),
          ],
        ),
        Icon(Icons.notifications_none, color: Colors.white70),
      ],
    );
  }

  Widget _buildFieldLabel(String label) {
    return Text(label, style: TextStyle(color: Color(0xFF00EEFC).withOpacity(0.7), fontSize: 12, fontWeight: FontWeight.bold, letterSpacing: 1.2));
  }

  Widget _buildTextField(String hint, IconData? icon, {String? prefix}) {
    return Container(
      margin: EdgeInsets.only(top: 12),
      padding: EdgeInsets.symmetric(horizontal: 20, vertical: 4),
      decoration: BoxDecoration(
        color: Colors.white.withOpacity(0.05),
        borderRadius: BorderRadius.circular(16),
        border: Border.all(color: Colors.white10),
      ),
      child: TextField(
        style: TextStyle(color: Colors.white, fontSize: 18),
        decoration: InputDecoration(
          border: InputBorder.none,
          hintText: hint,
          hintStyle: TextStyle(color: Colors.white24),
          icon: icon != null ? Icon(icon, color: Colors.white38, size: 20) : null,
          prefixText: prefix != null ? '$prefix ' : null,
          prefixStyle: TextStyle(color: Color(0xFF00EEFC), fontSize: 18),
        ),
      ),
    );
  }

  Widget _buildImpactSlider() {
    return Container(
      height: 8,
      width: double.infinity,
      decoration: BoxDecoration(color: Colors.white10, borderRadius: BorderRadius.circular(4)),
      child: FractionallySizedBox(
        alignment: Alignment.centerLeft,
        widthFactor: 0.35,
        child: Container(
          decoration: BoxDecoration(
            gradient: LinearGradient(colors: [Color(0xFF00EEFC), Colors.pinkAccent]),
            borderRadius: BorderRadius.circular(4),
          ),
        ),
      ),
    );
  }

  Widget _buildSubmitButton() {
    return Container(
      width: double.infinity,
      height: 60,
      decoration: BoxDecoration(
        color: Color(0xFF00EEFC),
        borderRadius: BorderRadius.circular(16),
        boxShadow: [BoxShadow(color: Color(0xFF00EEFC).withOpacity(0.3), blurRadius: 20, offset: Offset(0, 4))],
      ),
      child: Center(
        child: Row(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Icon(Icons.add_circle_outline, color: Color(0xFF051424)),
            SizedBox(width: 12),
            Text('REGISTRAR NO MARK I', style: TextStyle(color: Color(0xFF051424), fontWeight: FontWeight.bold, fontSize: 16, letterSpacing: 1)),
          ],
        ),
      ),
    );
  }
}
