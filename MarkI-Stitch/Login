import 'package:flutter/material.dart';

// --- Login e Cadastro Screen ---
class LoginScreen extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: Color(0xFF010F1F),
      body: Container(
        width: double.infinity,
        decoration: BoxDecoration(
          image: DecorationImage(
            image: NetworkImage('https://images.unsplash.com/photo-1446776811953-b23d57bd21aa?q=80&w=2072&auto=format&fit=crop'), // Placeholder para o fundo de estrelas
            fit: BoxFit.cover,
            colorFilter: ColorFilter.mode(Color(0xFF010F1F).withOpacity(0.8), BlendMode.multiply),
          ),
        ),
        child: SafeArea(
          child: Center(
            child: SingleChildScrollView(
              padding: EdgeInsets.symmetric(horizontal: 32),
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  _buildBrand(),
                  SizedBox(height: 60),
                  _buildLoginCard(),
                  SizedBox(height: 40),
                  _buildFooterStatus(),
                ],
              ),
            ),
          ),
        ),
      ),
    );
  }

  Widget _buildBrand() {
    return Row(
      mainAxisAlignment: MainAxisAlignment.center,
      children: [
        Icon(Icons.rocket_launch, color: Color(0xFF00EEFC), size: 32),
        SizedBox(width: 12),
        Text(
          'FINANÇAS MARK I',
          style: TextStyle(
            fontSize: 24,
            fontWeight: FontWeight.bold,
            letterSpacing: -1,
            color: Colors.white,
          ),
        ),
      ],
    );
  }

  Widget _buildLoginCard() {
    return Container(
      padding: EdgeInsets.all(32),
      decoration: BoxDecoration(
        color: Colors.white.withOpacity(0.03),
        borderRadius: BorderRadius.circular(32),
        border: Border.all(color: Colors.white.withOpacity(0.05)),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.3),
            blurRadius: 40,
            offset: Offset(0, 20),
          ),
        ],
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Text(
            'Bem-vindo,\nComandante.',
            style: TextStyle(
              fontSize: 42,
              fontWeight: FontWeight.bold,
              color: Colors.white,
              height: 1.1,
            ),
          ),
          SizedBox(height: 16),
          Text(
            'Configure seus instrumentos de navegação financeira para iniciar a missão.',
            style: TextStyle(color: Colors.white60, fontSize: 14),
          ),
          SizedBox(height: 40),
          _buildInputField('ASSINATURA DO PILOTO', 'Ex: Neil Armstrong', Icons.person_outline),
          SizedBox(height: 24),
          _buildInputField('GANHO MENSAL (CRÉDITOS)', '0.00', Icons.account_balance_wallet_outlined, suffix: 'BRL'),
          SizedBox(height: 40),
          _buildActionButton(),
        ],
      ),
    );
  }

  Widget _buildInputField(String label, String hint, IconData icon, {String? suffix}) {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Text(
          label,
          style: TextStyle(
            color: Colors.white38,
            fontSize: 10,
            fontWeight: FontWeight.bold,
            letterSpacing: 1.2,
          ),
        ),
        SizedBox(height: 12),
        Container(
          padding: EdgeInsets.symmetric(horizontal: 20, vertical: 4),
          decoration: BoxDecoration(
            color: Colors.white.withOpacity(0.05),
            borderRadius: BorderRadius.circular(16),
            border: Border.all(color: Colors.white10),
          ),
          child: TextField(
            style: TextStyle(color: Colors.white, fontSize: 16),
            decoration: InputDecoration(
              border: InputBorder.none,
              hintText: hint,
              hintStyle: TextStyle(color: Colors.white24),
              icon: Icon(icon, color: Colors.white38, size: 20),
              suffixText: suffix,
              suffixStyle: TextStyle(color: Colors.white24, fontSize: 12),
            ),
          ),
        ),
      ],
    );
  }

  Widget _buildActionButton() {
    return Container(
      width: double.infinity,
      height: 64,
      decoration: BoxDecoration(
        color: Color(0xFF00EEFC),
        borderRadius: BorderRadius.circular(20),
        boxShadow: [
          BoxShadow(
            color: Color(0xFF00EEFC).withOpacity(0.3),
            blurRadius: 24,
            offset: Offset(0, 8),
          ),
        ],
      ),
      child: Center(
        child: Row(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Text(
              'Iniciar Jornada',
              style: TextStyle(
                color: Color(0xFF010F1F),
                fontWeight: FontWeight.bold,
                fontSize: 18,
              ),
            ),
            SizedBox(width: 12),
            Icon(Icons.arrow_forward, color: Color(0xFF010F1F)),
          ],
        ),
      ),
    );
  }

  Widget _buildFooterStatus() {
    return Row(
      mainAxisAlignment: MainAxisAlignment.spaceBetween,
      children: [
        Row(
          children: [
            Container(
              width: 8,
              height: 8,
              decoration: BoxDecoration(color: Color(0xFF00EEFC), shape: BoxShape.circle),
            ),
            SizedBox(width: 8),
            Text('SISTEMAS ONLINE', style: TextStyle(color: Colors.white38, fontSize: 10, letterSpacing: 1)),
          ],
        ),
        Text('MARK_I_PROTO_V.01', style: TextStyle(color: Colors.white24, fontSize: 10, letterSpacing: 1)),
      ],
    );
  }
}
