              child: Text('GERENCIAR CONTRATOS', style: TextStyle(color: Colors.white, fontSize: 12, letterSpacing: 1.2)),
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildInstallmentItem(String title, String count, double progress) {
    return Padding(
      padding: EdgeInsets.only(bottom: 16),
      child: Column(
        children: [
          Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: [
              Text(title, style: TextStyle(color: Colors.white, fontSize: 14)),
              Text(count, style: TextStyle(color: Colors.white38, fontSize: 12, fontFamily: 'monospace')),
            ],
          ),
          SizedBox(height: 8),
          Stack(
            children: [
              Container(height: 4, width: double.infinity, decoration: BoxDecoration(color: Colors.white10, borderRadius: BorderRadius.circular(2))),
              FractionallySizedBox(
                widthFactor: progress,
                child: Container(height: 4, decoration: BoxDecoration(color: Color(0xFF00EEFC), borderRadius: BorderRadius.circular(2))),
              ),
            ],
          ),
        ],
      ),
    );
  }

  Widget _buildTransactionHistory() {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Row(
          mainAxisAlignment: MainAxisAlignment.spaceBetween,
          children: [
            Text('Registros de\nTransação', style: TextStyle(fontSize: 32, fontWeight: FontWeight.bold, color: Colors.white, height: 1.1)),
