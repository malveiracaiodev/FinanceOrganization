  Widget _buildBar(double heightFactor, bool isHighlight) {
    return Container(
      width: 30,
      height: 100 * heightFactor,
      decoration: BoxDecoration(
        color: isHighlight ? Colors.pinkAccent.withOpacity(0.3) : Color(0xFF00EEFC).withOpacity(0.2),
        borderRadius: BorderRadius.circular(4),
        border: Border.all(color: isHighlight ? Colors.pinkAccent.withOpacity(0.5) : Color(0xFF00EEFC).withOpacity(0.3)),
      ),
    );
  }

