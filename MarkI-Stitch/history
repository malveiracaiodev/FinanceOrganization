              padding: EdgeInsets.symmetric(horizontal: 12, vertical: 6),
              decoration: BoxDecoration(color: Color(0xFF00EEFC).withOpacity(0.1), borderRadius: BorderRadius.circular(20), border: Border.all(color: Color(0xFF00EEFC).withOpacity(0.3))),
              child: Text('TODOS', style: TextStyle(color: Color(0xFF00EEFC), fontSize: 10, fontWeight: FontWeight.bold)),
            ),
          ],
        ),
        SizedBox(height: 24),
        _buildTransactionCard('Supermercado Orbital', '14 AGO 2024 • Alimentação', '- R\$ 842,50', 'DÉBITO DIRETO', Icons.shopping_cart, false),
        _buildTransactionCard('Neuralink Setup', '12 AGO 2024 • Tecnologia', '- R\$ 1.200,00', 'CARTÃO DE CRÉDITO', Icons.videocam, true, label: '02/10'),
        _buildTransactionCard('Aportes Dividendos', '10 AGO 2024 • Investimentos', '+ R\$ 2.150,00', 'TRANSFERÊNCIA PIX', Icons.account_balance_wallet, false, isPositive: true),
      ],
    );
  }

  Widget _buildTransactionCard(String title, String subtitle, String amount, String method, IconData icon, bool hasBorder, {bool isPositive = false, String? label}) {
    return Container(
      margin: EdgeInsets.only(bottom: 16),
      padding: EdgeInsets.all(20),
      decoration: BoxDecoration(
        color: Colors.white.withOpacity(0.02),
        borderRadius: BorderRadius.circular(20),
        border: Border.all(color: hasBorder ? Colors.pinkAccent.withOpacity(0.3) : Colors.white.withOpacity(0.05)),
      ),
      child: Row(
        children: [
          Container(
            padding: EdgeInsets.all(12),
            decoration: BoxDecoration(color: Colors.white.withOpacity(0.05), borderRadius: BorderRadius.circular(16)),
            child: Icon(icon, color: isPositive ? Color(0xFF00EEFC) : Colors.white),
          ),
          SizedBox(width: 16),
          Expanded(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Row(
                  children: [
                    Text(title, style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold, fontSize: 16)),
                    if (label != null) ...[
                      SizedBox(width: 8),
                      Container(
                        padding: EdgeInsets.symmetric(horizontal: 6, vertical: 2),
                        decoration: BoxDecoration(color: Colors.white10, borderRadius: BorderRadius.circular(4)),
                        child: Text(label, style: TextStyle(color: Colors.white38, fontSize: 10)),
                      ),
                    ]
                  ],
                ),
                SizedBox(height: 4),
                Row(
                  children: [
                    Icon(Icons.calendar_today, size: 10, color: Colors.white38),
                    SizedBox(width: 4),
                    Text(subtitle, style: TextStyle(color: Colors.white38, fontSize: 11)),
                  ],
                ),
              ],
            ),
          ),
          Column(
            crossAxisAlignment: CrossAxisAlignment.end,
            children: [
              Text(amount, style: TextStyle(color: isPositive ? Color(0xFF00EEFC) : Colors.white, fontWeight: FontWeight.bold, fontSize: 18)),
              Text(method, style: TextStyle(color: Colors.white24, fontSize: 8)),
            ],
          ),
        ],
      ),
    );
  }
}
